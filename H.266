            text = (
                "Пресеты для H.266 (VVC):\n"
                "• faster: Очень быстро, черновые тесты.\n"
                "• fast: Быстрое кодирование, компромисс.\n"
                "• medium: Оптимальный баланс (Рекомендуется).\n"
                "• slow: Высокое сжатие, медленно.\n"
                "• slower: Экстремально медленно."
            )
        else:
            text = "Пресеты кодирования (скорость vs качество):\nЧем медленнее пресет, тем лучше сжатие при том же битрейте."
        if hasattr(self, 'preset_tooltip') and self.preset_tooltip:
            self.preset_tooltip.text = text

