        ttk.Label(frame, text="FPS:").grid(row=row, column=0, sticky=tk.W, pady=4)
        fps_frame = ttk.Frame(frame)
        fps_frame.grid(row=row, column=1, sticky=(tk.W, tk.E), padx=(8, 0), pady=4)
        ttk.Entry(fps_frame, textvariable=self.video_fps, width=10).pack(side=tk.LEFT, fill=tk.X, expand=True)

