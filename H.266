        self.saving_label.grid(row=2, column=1, sticky=tk.W, padx=(8, 0), pady=2)

    def create_context_menu(self):
        self.context_menu = tk.Menu(self.log_text, tearoff=0, font=('Segoe UI', 9))
        self.context_menu.add_command(label="Копировать", command=self.copy_text)
        self.context_menu.add_command(label="Выделить всё", command=self.select_all_text)
        self.context_menu.add_command(label="Очистить", command=self.clear_log)

        self.log_text.bind("<Button-3>", self.show_context_menu)
        self.log_text.bind("<Control-a>", lambda event: self.select_all_text())
        self.log_text.bind("<Control-A>", lambda event: self.select_all_text())
        self.log_text.bind("<Control-c>", lambda event: self.copy_text())
        self.log_text.bind("<Control-C>", lambda event: self.copy_text())

    def show_context_menu(self, event):
        try:
            self.context_menu.tk_popup(event.x_root, event.y_root)
        finally:
            self.context_menu.grab_release()

    def copy_text(self):
        try:
            selected_text = self.log_text.get(tk.SEL_FIRST, tk.SEL_LAST)
            self.root.clipboard_clear()
            self.root.clipboard_append(selected_text)
        except tk.TclError:
            pass

    def select_all_text(self):
        self.log_text.tag_add(tk.SEL, "1.0", tk.END)
        self.log_text.mark_set(tk.INSERT, "1.0")
        self.log_text.see(tk.INSERT)
        return "break"

    def clear_log(self):
        self.log_text.delete('1.0', tk.END)

    def browse_input(self):
        initial_dir = self.config.get("last_input_dir", "")
        filename = filedialog.askopenfilename(
            title="Выберите входной файл",
            initialdir=initial_dir if initial_dir and Path(initial_dir).exists() else None,
            filetypes=[("Все файлы", "*.*"), ("Видео", "*.mp4 *.avi *.mkv *.mov *.wmv"), ("Аудио", "*.mp3 *.wav *.aac")]
        )
        if filename:
            self.input_file.set(filename)
            self.config["last_input_dir"] = str(Path(filename).parent)
            
            if not self.output_file.get():
                input_path = Path(filename)
                output_path = input_path.parent / f"{input_path.stem}_converted.mp4"
                self.output_file.set(str(output_path))
            
            self.auto_detect_video_params(filename)

    def browse_output(self):
        initial_dir = self.config.get("last_output_dir", "")
        filename = filedialog.asksaveasfilename(
            title="Сохранить как",
            initialdir=initial_dir if initial_dir and Path(initial_dir).exists() else None,
            defaultextension=".mp4",
            filetypes=[("MP4", "*.mp4"), ("MKV", "*.mkv"), ("Все", "*.*")]
        )
        if filename:
            self.output_file.set(filename)
            self.config["last_output_dir"] = str(Path(filename).parent)
            self.update_file_info()

    def update_file_info(self, video_info=None):
        input_path = self.input_file.get()
        output_path = self.output_file.get()

        if input_path and Path(input_path).exists():
            info_parts = []
            size = os.path.getsize(input_path)
            info_parts.append(self.format_file_size(size))
            
            if not video_info:
                # В случае синхронного обновления UI
                video_info = self.get_video_info(input_path)
                
            if video_info:
                if video_info['duration']:
                    info_parts.append(self.format_duration(video_info['duration']))
                    self.video_duration = video_info['duration']
                    if not self.enable_trim.get():
                        self.trim_end.set(self.seconds_to_timestamp(video_info['duration']))
                        self.update_trim_duration_label()
                
                if video_info['format']:
                    format_name = video_info['format'].split(',')[0].split('/')[0].strip()
                    info_parts.append(format_name[:15] + "..." if len(format_name) > 15 else format_name)
                
                video_parts = []
                if video_info['video_codec']:
                    codec_name = video_info['video_codec'].split('/')[0].strip()
                    video_parts.append(codec_name.split('(')[0].strip()[:15])
                if video_info['video_bitrate']: video_parts.append(video_info['video_bitrate'])
                if video_info['resolution']:
                    video_parts.append(f"{video_info['resolution']}@{video_info.get('fps', '')}fps")
                if video_parts: info_parts.append(", ".join(video_parts))
                
                audio_parts = []
                if video_info['audio_codec']: audio_parts.append(video_info['audio_codec'].split('(')[0].strip()[:10])
                if video_info['audio_bitrate']: audio_parts.append(video_info['audio_bitrate'])
                if audio_parts: info_parts.append(", ".join(audio_parts))
            
            self.input_info_label.config(text=" | ".join(info_parts))
        else:
            self.input_info_label.config(text="Не выбран")

        if output_path and Path(output_path).exists():
            self.output_info_label.config(text=self.format_file_size(os.path.getsize(output_path)))
        else:
            self.output_info_label.config(text="Не создан")

        self.calculate_saving()

    def update_trim_duration_label(self):
        try:
            start_seconds = self.timestamp_to_seconds(self.trim_start.get())
            end_seconds = self.timestamp_to_seconds(self.trim_end.get())
            if end_seconds > start_seconds:
                self.duration_label.config(text=f"Длительность: {self.seconds_to_timestamp(end_seconds - start_seconds)}")
            else:
                self.duration_label.config(text="")
        except:
            self.duration_label.config(text="")

    def timestamp_to_seconds(self, timestamp):
        parts = timestamp.split(':')
        if len(parts) == 3: return float(parts[0])*3600 + float(parts[1])*60 + float(parts[2])
        elif len(parts) == 2: return float(parts[0])*60 + float(parts[1])
        else: return float(parts[0])

    def seconds_to_timestamp(self, seconds):
        return f"{int(seconds // 3600):02d}:{int((seconds % 3600) // 60):02d}:{int(seconds % 60):02d}"

    def format_duration(self, seconds):
        try:
            seconds = int(float(seconds))
            h, m, s = seconds // 3600, (seconds % 3600) // 60, seconds % 60
            return f"{h:02d}:{m:02d}:{s:02d}" if h > 0 else f"{m:02d}:{s:02d}"
        except:
            return "—"

    def format_file_size(self, size_bytes):
        if size_bytes == 0: return "0 Б"
        size_names = ["Б", "КБ", "МБ", "ГБ", "ТБ"]
        i = 0
        while size_bytes >= 1024 and i < len(size_names) - 1:
            size_bytes /= 1024.0; i += 1
        return f"{size_bytes:.1f} {size_names[i]}"

    def calculate_saving(self):
        input_path, output_path = self.input_file.get(), self.output_file.get()
        if input_path and output_path and Path(input_path).exists() and Path(output_path).exists():
            input_size, output_size = os.path.getsize(input_path), os.path.getsize(output_path)
            if input_size > 0:
                saving_percent = (1 - output_size / input_size) * 100
                if saving_percent > 0: self.saving_label.config(text=f"{saving_percent:.1f}% (меньше)", foreground=self.colors['success'])
                else: self.saving_label.config(text=f"{abs(saving_percent):.1f}% (больше)", foreground=self.colors['danger'])
            else: self.saving_label.config(text="0%")
        else:
            self.saving_label.config(text="0%", foreground=self.colors['dark'])

    def auto_detect_video_params(self, filepath):
        """Асинхронное определение параметров видео (без зависаний UI)"""
        self.root.config(cursor="watch")
        threading.Thread(target=self._auto_detect_thread, args=(filepath,), daemon=True).start()

    def _auto_detect_thread(self, filepath):
        video_info = self.get_video_info(filepath)
        self.root.after(0, self._apply_video_params, filepath, video_info)

    def _apply_video_params(self, filepath, video_info):
        self.root.config(cursor="")
        if video_info:
            if video_info['resolution']:
                self.original_resolution = video_info['resolution']
                self.video_resolution.set(video_info['resolution'])
                self.resolution_mode.set("Исходное")
                self.custom_resolution_entry.grid_remove()
                self.log(f"Определено разрешение: {video_info['resolution']}", "info")
            if video_info['fps']:
                self.video_fps.set(video_info['fps'])
                self.log(f"Определено FPS: {video_info['fps']}", "info")
            if video_info['duration']:
                self.video_duration = video_info['duration']
                self.trim_end.set(self.seconds_to_timestamp(video_info['duration']))
                self.log(f"Длительность: {self.format_duration(video_info['duration'])}", "info")
            
            self.update_file_info(video_info)
        else:
            self.log("Не удалось автоматически определить параметры видео", "warning")
            self.update_file_info()

    def get_video_info(self, filepath):
        try:
            if not Path(filepath).exists(): return None
            cmd = [self.get_ffprobe_path(), '-v', 'quiet', '-print_format', 'json', '-show_streams', '-show_format', filepath]
            
            flags = getattr(subprocess, 'CREATE_NO_WINDOW', 0) if os.name == 'nt' else 0
            result = subprocess.run(cmd, capture_output=True, text=True, errors='replace', timeout=30, creationflags=flags)
            
            if result.returncode == 0 and result.stdout:
                try: data = json.loads(result.stdout)
                except json.JSONDecodeError: return None
                
                info = {k: None for k in ['resolution', 'fps', 'video_codec', 'video_bitrate', 'audio_codec', 'audio_bitrate', 'duration', 'format', 'audio_channels', 'audio_sample_rate']}
                format_data = data.get('format', {})
                info['format'] = format_data.get('format_long_name', format_data.get('format_name', 'Неизвестен'))
                if format_data.get('duration'):
                    try: info['duration'] = float(format_data['duration'])
                    except: pass

                for stream in data.get('streams', []):
                    ctype = stream.get('codec_type')
                    if ctype == 'video' and not info['video_codec']:
                        w, h = stream.get('width'), stream.get('height')
                        info['resolution'] = f"{w}x{h}" if w and h else None
                        avg_fr = stream.get('avg_frame_rate')
                        if avg_fr and avg_fr != '0/0':
                            try:
                                num, den = map(int, avg_fr.split('/'))
                                if den != 0: info['fps'] = str(int(num / den))
                            except: pass
                        info['video_codec'] = stream.get('codec_long_name', stream.get('codec_name', 'Неизвестен'))
                        if stream.get('bit_rate'):
                            try: info['video_bitrate'] = f"{int(stream['bit_rate']) // 1000} kbps"
                            except: pass
                    elif ctype == 'audio' and not info['audio_codec']:
                        info['audio_codec'] = stream.get('codec_long_name', stream.get('codec_name', 'Неизвестен'))
                        if stream.get('bit_rate'):
                            try: info['audio_bitrate'] = f"{int(stream['bit_rate']) // 1000} kbps"
                            except: pass
                        ch = stream.get('channels')
                        if ch: info['audio_channels'] = f"{ch} ({stream.get('channel_layout', '')})" if stream.get('channel_layout') else str(ch)
                        sr = stream.get('sample_rate')
                        if sr:
                            try: info['audio_sample_rate'] = f"{int(sr) // 1000} kHz"
                            except: pass
                return info
            return None
        except Exception: 
            return None

    def get_ffprobe_path(self):
        if hasattr(self, 'ffprobe_path') and Path(self.ffprobe_path).exists():
            return self.ffprobe_path
        exe_suffix = '.exe' if os.name == 'nt' else ''
        try:
            p = Path(self.ffmpeg_path)
            candidate = p.parent / f'ffprobe{exe_suffix}'
            if candidate.exists(): return str(candidate)
        except Exception: pass
        return f'ffprobe{exe_suffix}'

    def check_ffmpeg_and_codecs(self):
        """Асинхронная проверка FFmpeg (Без зависания UI)"""
        self.root.config(cursor="watch")
        threading.Thread(target=self._check_ffmpeg_thread, daemon=True).start()

    def _check_ffmpeg_thread(self):
        try:
            flags = getattr(subprocess, 'CREATE_NO_WINDOW', 0) if os.name == 'nt' else 0
            
            # Проверка версии
            result = subprocess.run([self.ffmpeg_path, '-version'], capture_output=True, text=True, errors='replace', timeout=15, creationflags=flags)
            if result.returncode != 0:
                stderr_text = '\n'.join((result.stderr or '').strip().splitlines()[-5:]) or '(пустой stderr)'
                raise RuntimeError(f"FFmpeg вернул код {result.returncode}.\nstderr:\n{stderr_text}")
            
            version_lines = result.stdout.split('\n')
            self.ffmpeg_version_info = version_lines[0] if version_lines else "Неизвестная версия"
            self.ffmpeg_build_config = next((l.strip() for l in version_lines[1:4] if 'configuration:' in l), "Информация о сборке недоступна")
            
            # Проверка доступных кодеков
            result = subprocess.run([self.ffmpeg_path, '-encoders'], capture_output=True, text=True, errors='replace', timeout=20, creationflags=flags)
            self.supported_encoders, self.all_video_encoders, self.all_audio_encoders = [], [], []
            self.video_encoder_descriptions, self.audio_encoder_descriptions = {}, {}
            encoders_info = []
            
            in_encoders = False
            for line in result.stdout.split('\n'):
                if '------' in line: in_encoders = True; continue
                if in_encoders and line.strip():
                    parts = line.strip().split(maxsplit=2)
                    if len(parts) >= 2:
                        etype, ename, edesc = parts[0], parts[1], parts[2] if len(parts) >= 3 else parts[1]
                        if 'V' in etype:
                            self.all_video_encoders.append(ename); self.video_encoder_descriptions[ename] = edesc
                            if ename in CodecManager.VIDEO_CODECS: self.supported_encoders.append(ename); encoders_info.append(CodecManager.get_display_name(ename))
                        elif 'A' in etype:
                            self.all_audio_encoders.append(ename); self.audio_encoder_descriptions[ename] = edesc
                            if ename in CodecManager.AUDIO_CODECS: self.supported_encoders.append(ename); encoders_info.append(CodecManager.get_display_name(ename))

            # Парсинг точных версий кодеков (H.266 и AV1)
            self._detect_codec_versions()

            # Обновление UI
            self.root.after(0, self._apply_ffmpeg_check_success, encoders_info)

            # Проверка HW-ускорения (также в фоне)
            self.hw_availability = CodecManager.detect_hw_availability(self.all_video_encoders)
            self.hw_runtime_availability = {}
            self.hw_runtime_errors = {}
            
            if any(self.hw_availability.values()):
                self.log(f"Доступные HW-бэкенды: {', '.join([k for k, v in self.hw_availability.items() if v])}", "info")
                for hw_name in CodecManager.HW_SUFFIXES:
                    if not self.hw_availability.get(hw_name, False): continue
                    ok, err = CodecManager.test_hw_runtime(self.ffmpeg_path, hw_name)
                    self.hw_runtime_availability[hw_name] = ok
                    if not ok: self.hw_runtime_errors[hw_name] = err
                    
                    msg = f"  ✓ {hw_name}: работает" if ok else f"  ✗ {hw_name}: не работает — {err}"
                    self.log(msg, "success" if ok else "warning")
            else:
                self.log("HW-ускорение недоступно в этой сборке FFmpeg (только ЦП).", "info")

            self.root.after(0, self.update_hw_combobox)

        except Exception as e:
            self.root.after(0, self._apply_ffmpeg_check_error, str(e))

    def _detect_codec_versions(self):
        """Определяет точные версии внешних библиотек через dummy-encode"""
        self.codec_versions = {}
        target_codecs = ["libvvenc", "libaom-av1", "librav1e"]
        
        flags = getattr(subprocess, 'CREATE_NO_WINDOW', 0) if os.name == 'nt' else 0
        
        for codec in target_codecs:
            if codec in self.supported_encoders:
                try:
                    cmd = [
                        self.ffmpeg_path, '-hide_banner', '-v', 'info', 
                        '-f', 'lavfi', '-i', 'color=c=black:s=16x16:d=0.1', 
                        '-pix_fmt', 'yuv420p', '-c:v', codec, '-f', 'null', '-'
                    ]
                    result = subprocess.run(cmd, capture_output=True, text=True, errors='replace', timeout=5, creationflags=flags)
                    stderr = result.stderr
                    
                    if codec == "libvvenc":
                        match = re.search(r'vvenc.*?(\d+\.\d+\.\d+[a-z0-9\-]*)', stderr, re.IGNORECASE)
                        self.codec_versions[codec] = match.group(1) if match else "Версия не определена"
                    elif codec == "libaom-av1":
                        match = re.search(r'libaom.*?(\d+\.\d+\.\d+[a-z0-9\-]*)', stderr, re.IGNORECASE)
                        self.codec_versions[codec] = match.group(1) if match else "Версия не определена"
                    elif codec == "librav1e":
                        match = re.search(r'rav1e.*?(\d+\.\d+\.\d+[a-z0-9\-]*)', stderr, re.IGNORECASE)
                        self.codec_versions[codec] = match.group(1) if match else "Версия не определена"
                except Exception:
                    self.codec_versions[codec] = "Ошибка получения версии"

    def _apply_ffmpeg_check_success(self, encoders_info):
        self.root.config(cursor="")
        self.log(f"FFmpeg найден: {self.ffmpeg_version_info}", "success")
        self._filter_codecs('video')
        self._filter_codecs('audio')
        self.update_hw_combobox()
        if not encoders_info:
            self.log("Не найдено поддерживаемых кодеков!", "warning")

    def _apply_ffmpeg_check_error(self, err_msg):
        self.root.config(cursor="")
        self.log(f"Ошибка при проверке FFmpeg: {err_msg}", "error")
        self.hw_availability = {}
        self.hw_runtime_availability = {}
        self.hw_runtime_errors = {}
        self.update_hw_combobox()

    def update_hw_combobox(self):
        if not hasattr(self, 'hw_combobox') or self.hw_combobox is None: return
        self._hw_items = [("ЦП (Программное)", "ЦП (Программное)", True, "")]

        for hw_name in CodecManager.HW_SUFFIXES:
            if not self.hw_availability.get(hw_name, False):
                self._hw_items.append((f"{hw_name} — недоступно", hw_name, False, "Нет в сборке FFmpeg."))
                continue
            
            rt = self.hw_runtime_availability.get(hw_name)
            if rt is True: self._hw_items.append((hw_name, hw_name, True, ""))
            elif rt is False: self._hw_items.append((f"{hw_name} — недоступно", hw_name, False, f"Ошибка: {self.hw_runtime_errors.get(hw_name)}"))
            else: self._hw_items.append((f"{hw_name} — проверяется…", hw_name, None, "Подождите…"))

        self.hw_combobox['values'] = [i[0] for i in self._hw_items]
        
        current_hw = self.hw_accel.get()
        current_display = next((i[0] for i in self._hw_items if i[1] == current_hw), None)
        if current_display is None:
            self.hw_accel.set("ЦП (Программное)"); self.hw_combobox.set("ЦП (Программное)")
        else:
            self.hw_combobox.set(current_display)

    def on_hw_mode_change(self, event=None):
        selected_display = self.hw_combobox.get()
        selected_item = next((i for i in getattr(self, '_hw_items', []) if i[0] == selected_display), None)
        if not selected_item: return
        
        disp, hw_name, available, reason = selected_item
        if available is True:
            self.hw_accel.set(hw_name)
            self.update_hw_combobox()
            return

        self.hw_accel.set("ЦП (Программное)")
        self.hw_combobox.set("ЦП (Программное)")
        self.update_hw_combobox()
        messagebox.showwarning("Режим недоступен", f"Режим недоступен. {reason}")

    def get_actual_video_codec(self):
        base_codec, hw_mode = self.video_codec.get(), self.hw_accel.get()
        if hw_mode == "ЦП (Программное)": return base_codec, False, ""

        def _fallback(reason):
            self.log(f"GPU недоступен: {reason}", "warning")
            return base_codec, True, reason

        if not self.hw_availability.get(hw_mode, False): return _fallback(f"Нет {hw_mode}")
        if self.hw_runtime_availability.get(hw_mode) is False: return _fallback("Ошибка проверки GPU")

        hw_codec = CodecManager.HW_MAP.get(hw_mode, {}).get(base_codec, base_codec)
        if hw_codec == base_codec: return _fallback("Нет аналога для GPU")
        if hw_codec not in self.all_video_encoders: return _fallback("Энкодер отсутствует")

        return hw_codec, False, ""

    def show_ffmpeg_settings(self):
        win = tk.Toplevel(self.root)
        win.title("Настройки FFmpeg")
        win.geometry("500x250")
        frame = ttk.Frame(win, padding="20"); frame.pack(fill=tk.BOTH, expand=True)

        radio_frame = ttk.Frame(frame)
        radio_frame.grid(row=0, column=0, sticky=tk.W, pady=(0, 15))
        ttk.Radiobutton(radio_frame, text="Системный FFmpeg (PATH)", variable=self.use_local_ffmpeg, value=False).pack(anchor=tk.W)
        ttk.Radiobutton(radio_frame, text="Локальный FFmpeg (папка программы)", variable=self.use_local_ffmpeg, value=True).pack(anchor=tk.W)
        
        ttk.Label(frame, text="Путь к системному FFmpeg (если выбран системный):").grid(row=1, column=0, sticky=tk.W, pady=5)
        path_frame = ttk.Frame(frame); path_frame.grid(row=2, column=0, sticky=(tk.W, tk.E), pady=(0, 15))
        path_var = tk.StringVar(value=self.config.get("ffmpeg_path", "ffmpeg"))
        ttk.Entry(path_frame, textvariable=path_var).grid(row=0, column=0, sticky=(tk.W, tk.E), padx=(0, 5))
        ttk.Button(path_frame, text="Обзор", command=lambda: path_var.set(filedialog.askopenfilename() or path_var.get())).grid(row=0, column=1)

        def vacuum_ffmpeg():
            sys_ffmpeg = shutil.which("ffmpeg")
            if not sys_ffmpeg:
                messagebox.showerror("Ошибка", "Системный FFmpeg не найден в PATH!")
                return
            try:
                local_ff = self.app_dir / ("ffmpeg.exe" if os.name == 'nt' else "ffmpeg")
                shutil.copy2(sys_ffmpeg, local_ff)
                sys_ffprobe = shutil.which("ffprobe")
                if sys_ffprobe:
                    local_pr = self.app_dir / ("ffprobe.exe" if os.name == 'nt' else "ffprobe")
                    shutil.copy2(sys_ffprobe, local_pr)
                self.use_local_ffmpeg.set(True)
                messagebox.showinfo("Успех", f"FFmpeg успешно скопирован в:\n{self.app_dir}")
            except Exception as e:
                messagebox.showerror("Ошибка", f"Не удалось скопировать: {e}")

        ttk.Button(frame, text="Найти и скопировать FFmpeg в папку программы", command=vacuum_ffmpeg).grid(row=3, column=0, sticky=tk.W, pady=(0, 15))

        def save():
            self.config["use_local_ffmpeg"] = self.use_local_ffmpeg.get()
            self.config["ffmpeg_path"] = path_var.get()
            self.config_manager.save(self.config)
            self.setup_ffmpeg_paths()
            win.destroy()
            self.check_ffmpeg_and_codecs()

        btn_frame = ttk.Frame(frame); btn_frame.grid(row=4, column=0, sticky=tk.E)
        ttk.Button(btn_frame, text="Сохранить", command=save).pack(side=tk.LEFT, padx=(0, 5))
        ttk.Button(btn_frame, text="Отмена", command=win.destroy).pack(side=tk.LEFT)

    def show_ffmpeg_info(self):
        win = tk.Toplevel(self.root); win.geometry("700x500")
        win.title("Информация о FFmpeg")
        text_widget = tk.Text(win, wrap=tk.WORD, font=('Consolas', 10), padx=10, pady=10)
        
        info_text = f"Версия FFmpeg: {self.ffmpeg_version_info}\n"
        info_text += f"Путь: {self.ffmpeg_path}\n\n"
        
        # Раздел с точными версиями кодеков
        if getattr(self, 'codec_versions', None):
            info_text += "=== Установленные версии кодеков ===\n"
            for codec, ver in self.codec_versions.items():
                info_text += f" • {codec}: {ver}\n"
            info_text += "\n"
        
        info_text += f"=== Конфигурация сборки ===\n{self.ffmpeg_build_config}"
        
        text_widget.insert(tk.END, info_text)
        text_widget.config(state='disabled')
        text_widget.pack(fill=tk.BOTH, expand=True)

    def preview_command(self):
        try: messagebox.showinfo("Команда", ' '.join(self.build_ffmpeg_command()))
        except Exception as e: messagebox.showerror("Ошибка", str(e))

    def normalize_bitrate(self, bitrate):
        bitrate = bitrate.strip()
        if bitrate and bitrate[-1].lower() not in ['k', 'm'] and bitrate.isdigit(): return bitrate + 'k'
        return bitrate

    def build_ffmpeg_command(self):
        FFmpegValidator.validate_file_path(self.input_file.get())
        v_bit = self.normalize_bitrate(self.video_bitrate.get())
        a_bit = self.normalize_bitrate(self.audio_bitrate.get())
        
        cmd = [self.ffmpeg_path]
        trim_duration_seconds = None
        if self.enable_trim.get():
            start_s = self.timestamp_to_seconds(self.trim_start.get())
            end_s = self.timestamp_to_seconds(self.trim_end.get())
            if end_s <= start_s: raise ValueError("Неверное время")
            trim_duration_seconds = end_s - start_s
            cmd.extend(['-ss', self.trim_start.get()])

        cmd.extend(['-i', self.input_file.get()])
        if trim_duration_seconds: cmd.extend(['-t', self.seconds_to_timestamp(trim_duration_seconds)])

        vcodec, _, _ = self.get_actual_video_codec()
        cmd.extend(['-c:v', vcodec, '-threads', '0'])

        if self.use_crf.get():
            q = self.video_quality.get()
            if "nvenc" in vcodec: cmd.extend(['-rc', 'vbr', '-cq', q])
            elif "amf" in vcodec: cmd.extend(['-rc', 'cqp', '-qp_i', q, '-qp_p', q])
            elif "qsv" in vcodec: cmd.extend(['-global_quality', q, '-look_ahead', '0'])
            elif vcodec == 'librav1e': cmd.extend(['-qp', q])
            elif vcodec in ('libaom-av1', 'libvpx-vp9'): cmd.extend(['-crf', q, '-b:v', '0'])
            else: cmd.extend(['-crf', q])
        else: cmd.extend(['-b:v', v_bit])

        preset = self.video_preset.get()
        SPEED_MAP = {'libaom-av1': {'faster': 6, 'fast': 4, 'medium': 2}, 'librav1e': {'faster': 8, 'medium': 4}, 'libvpx-vp9': {'faster': 5, 'medium': 2}}
        if "nvenc" not in vcodec and "amf" not in vcodec and "qsv" not in vcodec:
            if vcodec == 'libaom-av1': cmd.extend(['-cpu-used', str(SPEED_MAP[vcodec].get(preset, 2))])
            elif vcodec in ('librav1e', 'libvpx-vp9'): cmd.extend(['-speed', str(SPEED_MAP[vcodec].get(preset, 2))])
            else: cmd.extend(['-preset', preset])

        cmd.extend(['-s', self.video_resolution.get(), '-r', self.video_fps.get(), '-c:a', self.audio_codec.get(), '-b:a', a_bit])
        if self.audio_codec.get() == 'libopus': cmd.extend(['-ac', '2'])
        cmd.extend(['-y', self.output_file.get()])
        return cmd

    def start_conversion(self):
        try:
            cmd = self.build_ffmpeg_command()
            self._effective_duration = self._compute_effective_duration()
            self.convert_button.config(state='disabled', text="Конвертация...")
            self.stop_button.config(state='normal')
            self.progress_var.set(0)
            
            self.conversion_thread = threading.Thread(target=self.run_conversion, args=(cmd,))
            self.conversion_thread.daemon = True
            self.conversion_thread.start()
        except Exception as e:
            self.log(f"Ошибка: {e}", "error")

    def _compute_effective_duration(self):
        try:
            if self.enable_trim.get(): return self.timestamp_to_seconds(self.trim_end.get()) - self.timestamp_to_seconds(self.trim_start.get())
            if self.video_duration: return float(self.video_duration)
            return float(self.get_video_duration(self.input_file.get()))
        except: return 0.0

    def run_conversion(self, cmd):
        try:
            self.start_time = time.time()
            self.log(f"Команда: {' '.join(cmd)}", "info")
            flags = getattr(subprocess, 'CREATE_NO_WINDOW', 0) if os.name == 'nt' else 0
            
            self.current_process = subprocess.Popen(
                cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, 
                text=True, bufsize=1, encoding='utf-8', errors='replace', creationflags=flags
            )
            
            for line in self.current_process.stdout:
                line = line.strip()
                if line:
                    self._process_conversion_output(line)

            self.current_process.wait()
            self.root.after(0, self._on_conversion_done, self.current_process.returncode)
        except Exception as e:
            self.root.after(0, self._on_conversion_error, str(e))

    def _process_conversion_output(self, line):
        match = TIME_PATTERN.search(line)
        if match:
            # Апдейт прогресса безопасно через UI-поток
            self.root.after(0, self.update_progress_ui, match.group(1))
            
            # Троттлинг вывода кадров в лог
            current_time = time.time()
            if current_time - self.last_frame_log_time >= 1.0:
                self.log(line)
                self.last_frame_log_time = current_time
        else:
            self.log(line)

    def _on_conversion_done(self, return_code):
        if return_code == 0:
            self.progress_var.set(100)
            self.log("Конвертация завершена успешно!", "success")
            self.update_file_info()
        else: 
            # -15 означает SIGTERM (прервано пользователем)
            if return_code == -15 or return_code == 1:
                self.log("Конвертация прервана", "warning")
            else:
                self.log(f"Ошибка {return_code}", "error")
                
        self.convert_button.config(state='normal', text="Начать конвертацию")
        self.stop_button.config(state='disabled')
        self.current_process = None

    def _on_conversion_error(self, err):
        self.log(f"Ошибка выполнения: {err}", "error")
        self.convert_button.config(state='normal', text="Начать конвертацию")
        self.stop_button.config(state='disabled')
        self.current_process = None

    def update_progress_ui(self, time_part):
        """Обновляет полосу прогресса из главного потока"""
        try:
            h, m, s = map(float, time_part.split(":"))
            current_seconds = h * 3600 + m * 60 + s
            
            duration = getattr(self, '_effective_duration', 0.0)
            if duration <= 0: return
            
            progress = (current_seconds / duration) * 100
            self.progress_var.set(min(progress, 100))
            
            elapsed = time.time() - self.start_time
            if progress > 0:
                remaining = max(0, (elapsed / (progress / 100)) - elapsed)
                self.time_label.config(text=f"Осталось: {self.format_time(remaining)}")
            
            self.progress_label.config(text=f"Прогресс: {progress:.1f}%")
        except: 
            pass

    def format_time(self, seconds):
        if seconds < 0: return "00:00"
        h, m, s = int(seconds // 3600), int((seconds % 3600) // 60), int(seconds % 60)
        return f"{h:02d}:{m:02d}:{s:02d}" if h > 0 else f"{m:02d}:{s:02d}"

    def get_video_duration(self, filepath):
        try:
            cmd = [self.get_ffprobe_path(), '-v', 'quiet', '-show_entries', 'format=duration', '-of', 'default=noprint_wrappers=1:nokey=1', filepath]
            flags = getattr(subprocess, 'CREATE_NO_WINDOW', 0) if os.name == 'nt' else 0
            result = subprocess.run(cmd, capture_output=True, text=True, errors='replace', timeout=10, creationflags=flags)
            if result.returncode == 0 and result.stdout.strip(): return float(result.stdout.strip())
        except: pass
        return 0

    def stop_conversion(self):
        if self.current_process:
            try:
                self.log("Отправлен сигнал остановки...", "warning")
                self.current_process.terminate()
            except: 
                self.current_process.kill()
            finally:
                self.convert_button.config(state='normal')
                self.stop_button.config(state='disabled')

    def on_closing(self):
        self.config.update({
            "hw_accel": self.hw_accel.get(), 
            "video_codec": self.video_codec.get(), 
            "use_crf": self.use_crf.get(), 
            "use_local_ffmpeg": self.use_local_ffmpeg.get()
        })
        self.config_manager.save(self.config)
        if self.current_process: self.stop_conversion()
        self.root.destroy()

def main():
    root = TkinterDnD.Tk()
    app = FFmpegConverter(root)
    root.mainloop()

if __name__ == "__main__":
    main()
