        self.bitrate_entry.pack(side=tk.LEFT, fill=tk.X, expand=True)
        ToolTip(self.bitrate_entry, "Битрейт видео. Форматы: 384k, 2M")
        row += 1

        ttk.Label(frame, text="Разрешение:").grid(row=row, column=0, sticky=tk.W, pady=4)
