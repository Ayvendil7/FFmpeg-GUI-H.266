    def _filter_codecs(self, codec_type):
        is_video = codec_type == 'video'
        show_all_var = self.show_all_video_codecs if is_video else self.show_all_audio_codecs
        all_encoders = self.all_video_encoders if is_video else self.all_audio_encoders
        supported_base = CodecManager.VIDEO_CODECS if is_video else CodecManager.AUDIO_CODECS
        descriptions = self.video_encoder_descriptions if is_video else self.audio_encoder_descriptions
        combobox = self.video_codec_combobox if is_video else self.audio_codec_combobox
        target_var = self.video_codec if is_video else self.audio_codec
        tooltip_attr = '_video_tooltip' if is_video else '_audio_tooltip'

        codecs_to_show = all_encoders if show_all_var.get() else CodecManager.filter_supported(supported_base, self.supported_encoders)

        display_names = []
        for codec in codecs_to_show:
            if show_all_var.get() and hasattr(self, 'video_encoder_descriptions'): 
                desc = descriptions.get(codec, codec)
                if len(desc) > 60: desc = desc[:57] + "..."
                display_names.append(f"{codec} - {desc}")
            else:
                display_names.append(CodecManager.get_display_name(codec))

        combobox['values'] = display_names

        current_tech = target_var.get()
        if current_tech not in codecs_to_show and codecs_to_show:
            target_var.set(codecs_to_show[0])
            combobox.set(display_names[0])
        else:
            if show_all_var.get():
                desc = descriptions.get(current_tech, current_tech)
                if len(desc) > 60: desc = desc[:57] + "..."
                combobox.set(f"{current_tech} - {desc}")
            else:
                combobox.set(CodecManager.get_display_name(current_tech))

        if show_all_var.get():
            current_tooltip = getattr(self, tooltip_attr, None)
            if current_tooltip is None:
                setattr(self, tooltip_attr, ComboboxTooltip(combobox, descriptions))
        else:
            current_tooltip = getattr(self, tooltip_attr, None)
            if current_tooltip is not None:
                current_tooltip.destroy()
                setattr(self, tooltip_attr, None)
                
        if is_video:
            self.update_preset_tooltip()

    def _on_codec_change(self, codec_type):
        combobox = self.video_codec_combobox if codec_type == 'video' else self.audio_codec_combobox
        target_var = self.video_codec if codec_type == 'video' else self.audio_codec
        selected_display_name = combobox.get()
        
        if ' - ' in selected_display_name:
            tech_name = selected_display_name.split(' - ')[0].strip()
        else:
            tech_name = CodecManager.get_tech_name(selected_display_name)
            if tech_name == selected_display_name and selected_display_name not in CodecManager.CODEC_DISPLAY_NAMES.values():
                tech_name = selected_display_name
        
        target_var.set(tech_name)
        if codec_type == 'video':
            self.update_preset_tooltip()

    def toggle_encoding_mode(self):
        if self.use_crf.get():
            self.bitrate_label.config(text="Качество (CRF):")
            self.bitrate_entry.config(textvariable=self.video_quality)
        else:
            self.bitrate_label.config(text="Битрейт:")
            self.bitrate_entry.config(textvariable=self.video_bitrate)

    def on_custom_resolution_change(self, *args):
        if self.resolution_mode.get() == "Особое":
            self.video_resolution.set(self.custom_resolution.get())

    def on_resolution_mode_change(self, event):
        mode = self.resolution_mode.get()
        if mode == "Особое":
            self.custom_resolution_entry.grid()
            self.video_resolution.set(self.custom_resolution.get())
        else:
            self.custom_resolution_entry.grid_remove()
            if mode == "Исходное": self.video_resolution.set(self.original_resolution if self.original_resolution else "1280x720")
            elif mode == "VGA (640x480)": self.video_resolution.set("640x480")
            elif mode == "DVD (720x480)": self.video_resolution.set("720x480")
            elif mode == "DVD+ (960x540)": self.video_resolution.set("960x540")
            elif mode == "HD (1280x720)": self.video_resolution.set("1280x720")
            elif mode == "FHD (1920x1080)": self.video_resolution.set("1920x1080")

